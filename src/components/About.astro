---
import { about } from '../data/event';
---
<section id="about" class="cmhm-section cmhm-about">
  <div class="cmhm-about-grid">
    <div class="about-left">
      <div class="cmhm-shead">
        <div class="eyebrow">09 · The Organizer</div>
        <h2 class="stitle">Triathlon Bangladesh — a <span class="acc">port-city endurance brand.</span></h2>
      </div>
      <p class="about-mission">{about.mission}</p>
      <p class="sr-only">Triathlon Bangladesh organises endurance events — marathons, triathlons, open-water swims — across Chittagong and coastal Bangladesh.</p>
      <div class="about-mark">
        <img src="/assets/triathlon-bd-shield-white.png" alt="Triathlon Bangladesh — Swim · Ride · Run" />
        <div>
          <div class="am-h">Organised by Triathlon Bangladesh</div>
          <div class="am-s">In association with Chittagong City Corporation.</div>
        </div>
      </div>
    </div>
    <ul class="about-pillars">
      {about.pillars.map((p, i) => (
        <li>
          <div class="ap-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="ap-k">{p.k}</div>
          <div class="ap-s">{p.s}</div>
        </li>
      ))}
    </ul>
  </div>
</section>
