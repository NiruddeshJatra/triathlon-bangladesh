---
import { event, getCurrentEvent } from '../data/event';

const currentEvent = getCurrentEvent();
const eventBase = currentEvent ? `/events/${currentEvent.slug}` : null;
---
<footer class="cmhm-footer">
  <div class="cmhm-footer-grid">
    <div>
      <img src="/assets/triathlon-bd-shield-white.png" alt="Triathlon Bangladesh" class="ft-shield" />
      <p class="ft-org">Organised by <b>Triathlon Bangladesh</b>.</p>
    </div>
    <div>
      <div class="ft-h">Contact</div>
      <a href={`tel:${event.contact.phone}`}>+880 1303-358202</a>
      <a href={`mailto:${event.contact.email}`}>{event.contact.email}</a>
    </div>
    {eventBase && (
      <div>
        <div class="ft-h">Race</div>
        <a href={`${eventBase}#race`}>Categories</a>
        <a href={`${eventBase}#schedule`}>Schedule</a>
        <a href={`${eventBase}#route`}>Route</a>
        <a href={`${eventBase}#get`}>What you get</a>
      </div>
    )}
    <div>
      <div class="ft-h">More</div>
      <a href="/team">Our Team</a>
      <a href="/">Past events</a>
      <a href="/">About</a>
      {eventBase && <a href={`${eventBase}#faq`}>FAQ</a>}
    </div>
  </div>
  <div class="cmhm-footer-bot">
    <div>© 2026 Triathlon Bangladesh · All rights reserved</div>
    <div class="ft-tagline">Feel the pulse of the port city.</div>
    <div class="ft-credit">Made with ❤️ by <a href="https://niruddeshjatra.space" target="_blank" rel="noopener noreferrer">nj</a></div>
  </div>
</footer>
