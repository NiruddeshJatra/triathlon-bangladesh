---
import { event } from '../data/event';
---
<nav class="cmhm-nav">
  <a href="#top" class="cmhm-brand">
    <img src="/logo_transparent.png" alt="Chatto Metro Half Marathon" width="42" height="42" />
    <span><b>Chatto Metro</b> · Half Marathon</span>
  </a>
  <div id="nav-menu" class="cmhm-navlinks">
    <a href="#race">Race</a>
    <a href="#route">Route</a>
    <a href="#schedule">Schedule</a>
    <a href="#team">Team</a>
    <a href="#about">About</a>
    <a class="cmhm-nav-cta" href={event.registerUrl} target="_blank" rel="noopener noreferrer">Register</a>
  </div>
  <button id="nav-toggle" class="cmhm-nav-toggle"
          aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<script>
  const btn = document.getElementById('nav-toggle');
  const nav = btn?.closest('nav');
  const menu = document.getElementById('nav-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    const opening = !expanded;
    btn.setAttribute('aria-expanded', String(opening));
    nav?.classList.toggle('open');
    if (opening) {
      (menu?.querySelector('a') as HTMLElement)?.focus();
    }
  });

  // Close on link click (mobile)
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      nav?.classList.remove('open');
    });
  });
</script>
