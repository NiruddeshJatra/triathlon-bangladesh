---
import { getCurrentEvent } from '../data/event';

const currentEvent = getCurrentEvent();
---
<nav class="cmhm-nav">
  <a href="/" class="cmhm-brand">
    <img src="/cmhm-logo-for-dark.png" alt="Triathlon Bangladesh — Chatto Metro Half Marathon" width="53" height="42" style="width:auto;max-width:180px;" />
    <span><b>Triathlon</b> Bangladesh</span>
  </a>
  <div id="nav-menu" class="cmhm-navlinks">
    <a href="/">Home</a>
    {currentEvent && <a href={`/events/${currentEvent.slug}`}>Events</a>}
    <a href="/team">Our Team</a>
    <a href="/join">Join Our Team</a>
    <a href="/terms">Terms</a>
    {currentEvent?.registerUrl && <a class="cmhm-nav-cta" href={currentEvent.registerUrl} target="_blank" rel="noopener noreferrer">Register</a>}
  </div>
  <button id="nav-toggle" class="cmhm-nav-toggle"
          aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<script>
  const btn = document.getElementById('nav-toggle');
  const nav = btn?.closest('nav');
  const menu = document.getElementById('nav-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    const opening = !expanded;
    btn.setAttribute('aria-expanded', String(opening));
    nav?.classList.toggle('open');
    if (opening) {
      (menu?.querySelector('a') as HTMLElement)?.focus();
    }
  });

  // Close on link click (mobile)
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      nav?.classList.remove('open');
    });
  });
</script>
