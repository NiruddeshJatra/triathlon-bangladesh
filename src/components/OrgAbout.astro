---
import { org } from '../data/event';
---
<section class="cmhm-section cmhm-org-about">
  <div class="cmhm-about-grid">
    <div class="about-left">
      <div class="cmhm-shead">
        <div class="eyebrow">The Organisation</div>
        <h2 class="stitle">Triathlon Bangladesh — a <span class="acc">port-city endurance brand.</span></h2>
      </div>
      <p class="about-mission">{org.mission}</p>
      <div class="about-mark">
        <img src="/assets/triathlon-bd-shield-white.png" alt="Triathlon Bangladesh — Swim · Bike · Run" />
        <div>
          <div class="am-h">{org.name}</div>
          <div class="am-s">{org.tagline}</div>
        </div>
      </div>
    </div>
    <ul class="about-pillars">
      {org.pillars.map((p, i) => (
        <li>
          <div class="ap-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="ap-k">{p.k}</div>
          <div class="ap-s">{p.s}</div>
        </li>
      ))}
    </ul>
  </div>
</section>
