---
import { previousEvents, stats } from '../data/event';
import CountUp from '../islands/CountUp';
---
<section id="previous" class="cmhm-section cmhm-prev">
  <div class="cmhm-shead">
    <div class="eyebrow">08 · Track Record</div>
    <h2 class="stitle">Not our <span class="acc">first start line.</span></h2>
    <p class="skicker">Kutubdia, Moheshkhali, channel swims, boot camps. The Karnaphuli is the next chapter — not the opening one.</p>
  </div>

  <div class="cmhm-stats">
    {stats.map((s) => (
      <div class="stat">
        <div class="sn">
          <CountUp end={s.n} client:visible />{s.suffix}
        </div>
        <div class="sl">{s.l}</div>
      </div>
    ))}
  </div>

  <ol class="cmhm-prev-list">
    {previousEvents.map((e) => (
      <li>
        <div class="pe-year">{e.year}</div>
        <div class="pe-body">
          <div class="pe-title">{e.title}</div>
          <div class="pe-meta">
            <span>{e.date}</span>
            {e.runners && <span>· {e.runners} runners</span>}
            {e.dist && <span>· {e.dist}</span>}
          </div>
          {e.note && <div class="pe-note">{e.note}</div>}
        </div>
      </li>
    ))}
  </ol>
</section>
