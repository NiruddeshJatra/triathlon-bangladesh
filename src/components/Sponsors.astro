---
import { sponsors } from '../data/event';
---
<section id="sponsors" class="cmhm-section cmhm-spons">
  <div class="cmhm-shead">
    <div class="eyebrow">10 · Partners</div>
    <h2 class="stitle">Built with the <span class="acc">city.</span></h2>
    <p class="skicker">Powered by partners on the ground and on air.</p>
  </div>

  <div class="cmhm-spons-grid">
    <div class="sp-card">
      <div class="sp-role">{sponsors.timing.role}</div>
      <div class="sp-name">Total Active Sports</div>
    </div>
    <div class="sp-card">
      {sponsors.crew.logo && (
        <div class="sp-logo-wrap">
          <img src={sponsors.crew.logo} alt={sponsors.crew.name} />
        </div>
      )}
      <div class="sp-role">{sponsors.crew.role}</div>
      <div class="sp-name">{sponsors.crew.name}</div>
    </div>
    <div class="sp-card">
      {sponsors.promo.logo && (
        <div class="sp-logo-wrap">
          <img src={sponsors.promo.logo} alt={sponsors.promo.name} />
        </div>
      )}
      <div class="sp-role">{sponsors.promo.role}</div>
      <div class="sp-name">{sponsors.promo.name}</div>
    </div>
    <div class="sp-card sp-slot">
      <div class="sp-role">Title Sponsor</div>
      <div class="sp-name muted">Slot open · contact us</div>
    </div>
    <div class="sp-card sp-slot">
      <div class="sp-role">Gold Sponsor</div>
      <div class="sp-name muted">Slot open</div>
    </div>
  </div>

  <div class="cmhm-media">
    <div class="mh">Media partners</div>
    <div class="mlist">
      {sponsors.media.map((m) => <span>{m}</span>)}
    </div>
  </div>
</section>
