---
import { routePins, onCourse, categories } from '../data/event';

const ROUTE_PATH = "M 95 480 C 150 440 165 380 250 360 C 320 345 335 305 305 255 C 285 218 305 178 365 170 C 440 162 478 144 565 138";

const pinXY = [
  { x: 95,  y: 480 },
  { x: 305, y: 255 },
  { x: 565, y: 138 },
];

const kmTicks: [number, number][] = [
  [95,480],[116,460],[145,440],[180,420],[215,400],
  [250,360],[275,320],[290,290],[305,255],[320,230],[340,210],
];
---
<section id="route" class="cmhm-section cmhm-route-sec">
  <div class="cmhm-shead">
    <div class="eyebrow">05 · The Course</div>
    <h2 class="stitle">The <span class="acc">Karnaphuli</span> route.</h2>
    <p class="skicker">Flat. Riverside. West bank from Bastuhara out to Bangladesh Maritime University, then back.</p>
  </div>

  <div class="rcp-card">
    <div class="hr-badge hr-start">
      <span class="hr-badge-l">START</span>
      <span class="hr-badge-n">Bastuhara</span>
    </div>
    <div class="hr-badge hr-turn">
      <span class="hr-badge-l">TURN</span>
      <span class="hr-badge-n">Maritime University</span>
    </div>

    <svg id="course-svg" class="cmhm-map" viewBox="0 0 1000 560"
         preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="topo-c" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 0 30 Q 15 18 30 30 T 60 30" fill="none" stroke="rgba(212,175,55,.08)" stroke-width=".9" />
          <path d="M 0 50 Q 15 40 30 50 T 60 50" fill="none" stroke="rgba(127,184,154,.06)" stroke-width=".7" />
        </pattern>
        <linearGradient id="routeg-c" x1="0" y1="1" x2="1" y2="0">
          <stop offset="0" stop-color="var(--green-bright)" />
          <stop offset=".6" stop-color="var(--gold-soft)" />
          <stop offset="1" stop-color="var(--gold)" />
        </linearGradient>
        <filter id="glow-c" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3.2" result="b" />
          <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
      </defs>

      <!-- topographic land background -->
      <rect x="0" y="0" width="1000" height="560" fill="url(#topo-c)" />

      <!-- terrain grid -->
      <g stroke="rgba(127,184,154,.07)" stroke-width="1">
        {Array.from({ length: 14 }, (_, i) => (
          <line x1={i * 77} y1="0" x2={i * 77} y2="560" />
        ))}
        {Array.from({ length: 9 }, (_, i) => (
          <line x1="0" y1={i * 70} x2="1000" y2={i * 70} />
        ))}
      </g>

      <!-- route + pins shifted right to clear the START badge -->
      <g transform="translate(70, 0)">
        <!-- route shadow -->
        <path d={ROUTE_PATH} fill="none" stroke="rgba(255,255,255,.07)"
              stroke-width="5" stroke-linecap="round" />

        <!-- animated route line -->
        <path id="course-route" class="cmhm-route" d={ROUTE_PATH}
              fill="none" stroke="url(#routeg-c)" stroke-width="3.8"
              stroke-linecap="round" filter="url(#glow-c)" />

        <!-- pulsing highlight -->
        <path id="course-pulse" class="cmhm-pulse" d={ROUTE_PATH}
              fill="none" stroke="#fff" stroke-width="3.8" stroke-linecap="round" />

        <!-- km tick dots -->
        <g id="course-ticks" class="course-ticks">
          {kmTicks.map(([cx, cy], i) => (
            <circle cx={cx} cy={cy} r="2" fill="var(--gold-soft)" opacity={0.4 + i * 0.04} />
          ))}
        </g>

        <!-- waypoint pins -->
        {routePins.map((pin, i) => {
          const xy = pinXY[i] || pinXY[0];
          const delay = `${1.6 + pin.t * 1.0}s`;
          return (
            <g class="cmhm-pin" style={`transition-delay:${delay}`}>
              <line x1={xy.x} y1={xy.y} x2={xy.x} y2={xy.y - 22}
                    stroke="var(--gold)" stroke-width="1.5" />
              <circle cx={xy.x} cy={xy.y - 26} r="6" fill="var(--gold)"
                      stroke="#fff" stroke-width="1.5" />
              <circle cx={xy.x} cy={xy.y} r="3" fill="var(--gold)" />
              <text class="cmhm-pinlabel" x={xy.x + 14} y={xy.y - 28}>{pin.label}</text>
              <text class="cmhm-pinsub"   x={xy.x + 14} y={xy.y - 15}>{pin.sub}</text>
            </g>
          );
        })}
      </g>
    </svg>
  </div>

  <div class="route-below">
    <div class="route-col">
      <h3 class="route-side-h">Cut-off Times</h3>
      <ul class="route-cutoffs">
        {categories.map((cat) => (
          <li style={`--cat-c:${cat.colorHex}`}>
            <div class="rc-dist">{cat.distance}</div>
            <div class="rc-body">
              <div class="rc-name">{cat.name}</div>
              <div class="rc-meta">
                <span>Flag-off {cat.flagOff}</span>
                <span class="rc-sep">·</span>
                <span>Cut-off <b>{cat.cutoff}</b></span>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="route-col">
      <h3 class="route-side-h">On-course support</h3>
      <ul class="route-support">
        {onCourse.map((s) => (
          <li><span class="ok">●</span> <b>{s.k}</b> — {s.s}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script>
  const svg   = document.getElementById('course-svg');
  const route = document.getElementById('course-route');
  const pulse = document.getElementById('course-pulse');
  const ticks = document.getElementById('course-ticks');

  if (svg && route) {
    const pins = Array.from(svg.querySelectorAll<SVGGElement>('.cmhm-pin'));
    const pref = window.matchMedia('(prefers-reduced-motion: reduce)');

    const trigger = () => {
      route.classList.add('drawn');
      pulse?.classList.add('on');
      ticks?.classList.add('show');
      pins.forEach(p => p.classList.add('show'));
    };

    if (pref.matches) {
      trigger();
    } else {
      const obs = new IntersectionObserver(([e]) => {
        if (!e.isIntersecting) return;
        trigger();
        obs.disconnect();
      }, { threshold: 0.22 });
      obs.observe(svg);
    }
  }
</script>
