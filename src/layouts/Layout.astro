---
import '../styles/global.css';
import { event } from '../data/event';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${event.name} ${event.year} · ${event.organizer}`,
  description = `Half marathon in Chittagong (Chattogram), 10 July 2026 — 21.1K, 10K, 5K along the Karnaphuli riverside. Registration open. Organised by Triathlon Bangladesh.`,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://triathlonbangladesh.com';
const currentUrl = Astro.url?.href ?? siteUrl;

const jsonLdEvent = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": `${event.name} ${event.year}`,
  "startDate": event.flagOffISO,
  "endDate": event.endISO,
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": event.venueLong,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Bastuhara, Khetchar, Karnaphuli Bank Road",
      "addressLocality": "Chattogram",
      "addressRegion": "Chattogram Division",
      "addressCountry": "BD"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": event.venueGeo.lat,
      "longitude": event.venueGeo.lng
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": event.organizer,
    "url": siteUrl
  },
  "offers": {
    "@type": "Offer",
    "url": event.registerUrl,
    "validFrom": "2026-01-01",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "BDT"
  },
  "image": `${siteUrl}/og-image.jpg`,
  "description": description,
  "sport": "Running",
  "url": siteUrl
};

const jsonLdOrg = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": event.organizer,
  "url": siteUrl,
  "logo": `${siteUrl}/og-image.jpg`,
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": `+880-${event.contact.phone}`,
    "email": event.contact.email,
    "contactType": "customer service"
  }
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": `${event.name} ${event.year}`,
      "item": currentUrl
    }
  ]
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <!-- OG tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta name="twitter:image" content="/og-image.jpg" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.site?.toString() ?? 'https://triathlonbangladesh.com'} />
  <meta property="og:locale" content="en_US" />
  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <!-- Canonical -->
  <link rel="canonical" href={siteUrl} />
  <!-- Geo + locale -->
  <meta name="geo.region" content="BD-B" />
  <meta name="geo.placename" content="Chattogram, Bangladesh" />
  <meta name="geo.position" content={`${event.venueGeo.lat};${event.venueGeo.lng}`} />
  <meta name="ICBM" content={`${event.venueGeo.lat}, ${event.venueGeo.lng}`} />
  <meta http-equiv="content-language" content="en-BD" />
  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdEvent)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrg)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
<body class="bg-bg-base text-text-base">
  <slot />
</body>
</html>
