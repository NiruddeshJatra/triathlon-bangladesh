---
import '../styles/global.css';
import { event } from '../data/event';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${event.name} ${event.year} · ${event.organizer}`,
  description = `Run the Karnaphuli. 21.1K · 10K · 5K along ${event.venueShort}. ${event.dateDisplay}. Organised by ${event.organizer}.`,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <!-- OG tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta name="twitter:image" content="/og-image.jpg" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.site?.toString() ?? 'https://triathlonbangladesh.com'} />
  <meta property="og:locale" content="en_US" />
  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <!-- Canonical -->
  <link rel="canonical" href={Astro.site?.toString() ?? 'https://triathlonbangladesh.com'} />
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
<body class="bg-bg-base text-text-base">
  <slot />
</body>
</html>
