---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import QuickFacts from '../../components/QuickFacts.astro';
import WheelDivider from '../../components/WheelDivider.astro';
import Categories from '../../components/Categories.astro';
import Schedule from '../../components/Schedule.astro';
import TheCourse from '../../components/TheCourse.astro';
import Entitlements from '../../components/Entitlements.astro';
import Team from '../../components/Team.astro';
import PartnersSlideshow from '../../components/PartnersSlideshow.astro';
import FAQ from '../../components/FAQ.astro';
import RegisterBand from '../../components/RegisterBand.astro';
import Footer from '../../components/Footer.astro';
import ScrollRoute from '../../islands/ScrollRoute';
import WheelSpin from '../../islands/WheelSpin';
import { events, getEventBySlug } from '../../data/event';

export function getStaticPaths() {
  return events.map(e => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const eventEntry = getEventBySlug(slug!);

if (!eventEntry) {
  return Astro.redirect('/');
}

const isFullEvent = eventEntry.status === 'current';

const pageTitle = `${eventEntry.name} · Triathlon Bangladesh`;
const pageDesc = eventEntry.summary;
---
<Layout title={pageTitle} description={pageDesc}>
  {isFullEvent && <ScrollRoute client:visible />}
  {isFullEvent && <WheelSpin client:idle />}
  <Nav />
  <main>
    {isFullEvent ? (
      <>
        <Hero />
        <QuickFacts />
        <WheelDivider label="THE DISTANCES" />
        <Categories />
        <Schedule />
        <WheelDivider label="THE COURSE" />
        <TheCourse />
        <Entitlements />
        <WheelDivider label="THE CREW" />
        <Team />
        {eventEntry.partners && eventEntry.partners.length > 0 && (
          <PartnersSlideshow partners={eventEntry.partners} />
        )}
        <FAQ />
        <WheelDivider label="REGISTER" />
        <RegisterBand />
      </>
    ) : (
      <div class="ev-page">
        {/* Hero */}
        <div class={`ev-page-hero${eventEntry.heroImage ? ' ev-page-hero--img' : ''}`}>
          {eventEntry.heroImage && (
            <img class="ev-page-hero-img" src={eventEntry.heroImage} alt={eventEntry.name} loading="eager" />
          )}
          <div class="ev-page-hero-overlay" aria-hidden="true"></div>
          <div class="ev-page-hero-content">
            <div class="eyebrow ev-page-eyebrow">
              {eventEntry.eventType === 'program' ? 'Training Programme'
               : eventEntry.eventType === 'community' ? 'Rescue Partner · Community'
               : eventEntry.status === 'previous' ? 'Past Event'
               : 'Upcoming Event'}
              {' · '}{eventEntry.dateDisplay}
            </div>
            <h1 class="ev-page-title">{eventEntry.name}</h1>
            {eventEntry.tagline && <p class="ev-page-tagline">{eventEntry.tagline}</p>}
          </div>
        </div>

        {/* Body */}
        <div class="ev-page-body">
          {/* Key facts */}
          <div class="ev-page-facts">
            <div class="ev-fact">
              <div class="ev-fact-label">Date</div>
              <div class="ev-fact-val">{eventEntry.dateDisplay}</div>
            </div>
            <div class="ev-fact">
              <div class="ev-fact-label">Location</div>
              <div class="ev-fact-val">{eventEntry.location}</div>
            </div>
            {eventEntry.dist && (
              <div class="ev-fact">
                <div class="ev-fact-label">Distance</div>
                <div class="ev-fact-val">{eventEntry.dist}</div>
              </div>
            )}
            {eventEntry.runners && (
              <div class="ev-fact">
                <div class="ev-fact-label">Runners</div>
                <div class="ev-fact-val">{eventEntry.runners}</div>
              </div>
            )}
          </div>

          {/* Summary + note */}
          <p class="ev-page-summary">{eventEntry.summary}</p>
          {eventEntry.note && (
            <p class="ev-page-note">{eventEntry.note}</p>
          )}

          {/* CTAs */}
          <div class="ev-page-ctas">
            {eventEntry.registerUrl && eventEntry.status !== 'previous' && (
              <a class="cmhm-btn cmhm-btn-p" href={eventEntry.registerUrl} target="_blank" rel="noopener noreferrer">
                Register Now <span class="arr">→</span>
              </a>
            )}
            <a class="cmhm-btn cmhm-btn-s" href="/">← All Events</a>
          </div>

          {/* Gallery */}
          {eventEntry.gallery && eventEntry.gallery.length > 0 && (
            <div class="ev-page-gallery-wrap">
              <div class="eyebrow ev-gallery-eyebrow">Gallery</div>
              <div class="ev-page-gallery">
                {eventEntry.gallery.map((src, i) => (
                  <div class="ev-gallery-item">
                    <img src={src} alt={`${eventEntry.name} — photo ${i + 1}`} loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    )}
  </main>
  <Footer />
</Layout>
