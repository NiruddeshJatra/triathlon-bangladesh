---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import BrandHero from '../components/BrandHero.astro';
import TwoRegisterCTAs from '../components/TwoRegisterCTAs.astro';
import WheelDivider from '../components/WheelDivider.astro';
import UpcomingEventsList from '../components/UpcomingEventsList.astro';
import PreviousEventsList from '../components/PreviousEventsList.astro';
import OrgAbout from '../components/OrgAbout.astro';
import Footer from '../components/Footer.astro';
import WheelSpin from '../islands/WheelSpin';
---
<Layout
  title="Triathlon Bangladesh · Endurance Events · Chattogram"
  description="Triathlon Bangladesh organises endurance events — half marathons, triathlons, open-water swims — across Chattogram and coastal Bangladesh. Next: Chatto Metro Half Marathon, 10 July 2026."
>
  <WheelSpin client:idle />
  <Nav />
  <main>
    <BrandHero />
    <TwoRegisterCTAs />
    <WheelDivider label="UPCOMING" />
    <UpcomingEventsList />
    <WheelDivider label="TRACK RECORD" />
    <PreviousEventsList />
    <WheelDivider label="THE MISSION" />
    <OrgAbout />
  </main>
  <Footer />
</Layout>
